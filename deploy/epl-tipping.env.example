ADMIN_TOKEN=replace-with-a-long-random-admin-token
ADMIN_COOKIE_SECRET=replace-with-a-different-long-random-cookie-secret
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_TTL_SECONDS=86400
FOOTBALL_DATA_TOKEN=replace-with-your-server-only-api-token
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
TIPPING_COMPETITION_CODE=PL
TIPPING_SEASON=2026
TIPPING_DATA_DIR=/var/lib/epl-tipping/data
TIPPING_COMPETITION_TIMEZONE=Australia/Sydney
TIPPING_ALLOWED_HOSTS=tipping.example.com,localhost,127.0.0.1
TIPPING_ENABLE_HSTS=true
